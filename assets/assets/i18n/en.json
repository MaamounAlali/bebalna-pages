  "privacy_title": "Privacy Policy",
  "privacy_last_updated": "Last updated: June 14, 2026",
  "privacy_intro": "Bebalna (ببالنا) helps households manage inventory, shopping, and family activity. This Privacy Policy explains what information we collect, how we use it, and the choices you have.",
  "privacy_section_collect_title": "Information we collect",
  "privacy_section_collect_body": "We collect information you provide when you create an account (such as your name and email), household and family data you add to the app (inventory items, shopping lists, reminders, and activity), and technical data needed to operate the service (such as device identifiers for push notifications).",
  "privacy_section_use_title": "How we use your information",
  "privacy_section_use_body": "We use your information to provide and improve Bebalna, authenticate your account, sync data within your family household, send optional notifications you enable, and keep the service secure.",
  "privacy_section_sharing_title": "Sharing within your household",
  "privacy_section_sharing_body": "Data you add to a family household is visible to members of that household according to their role. We do not sell your personal information. We may share data with service providers that help us run Bebalna (such as cloud hosting), subject to appropriate safeguards.",
  "privacy_section_security_title": "Data storage and security",
  "privacy_section_security_body": "Your data is transmitted over encrypted connections and stored using industry-standard cloud infrastructure. While we work to protect your information, no method of transmission or storage is completely secure.",
  "privacy_section_rights_title": "Your choices and rights",
  "privacy_section_rights_body": "You can update your profile, manage notification preferences, and leave a family household from within the app. You may request account deletion or access to your data by contacting us at the address below.",
  "privacy_section_contact_title": "Contact us",
  "privacy_section_contact_body": "Questions about this Privacy Policy can be sent to privacy@bebalna.app.",
  "terms_title": "Terms of Use",
  "terms_last_updated": "Last updated: June 14, 2026",
  "terms_intro": "These Terms of Use govern your access to and use of Bebalna. By creating an account or using the app, you agree to these terms.",
  "terms_section_acceptance_title": "Acceptance of terms",
  "terms_section_acceptance_body": "If you do not agree to these Terms of Use or our Privacy Policy, do not use Bebalna. We may update these terms from time to time, and continued use after changes means you accept the updated terms.",
  "terms_section_account_title": "Your account",
  "terms_section_account_body": "You are responsible for keeping your login credentials secure and for activity that occurs under your account. Provide accurate information when registering and notify us if you suspect unauthorized access.",
  "terms_section_use_title": "Acceptable use",
  "terms_section_use_body": "Use Bebalna only for lawful household management purposes. Do not misuse the service, attempt to access other users' data, interfere with app operation, or upload harmful or unlawful content.",
  "terms_section_family_title": "Family households",
  "terms_section_family_body": "When you join or create a family household, you understand that household data may be visible to other members. Only invite people you trust, and use household roles responsibly.",
  "terms_section_availability_title": "Service availability",
  "terms_section_availability_body": "Bebalna is provided on an \"as is\" basis. We may change, suspend, or discontinue features as the product evolves. We do not guarantee uninterrupted availability.",
  "terms_section_changes_title": "Changes to the service",
  "terms_section_changes_body": "We may modify Bebalna, including adding or removing features, to improve the experience or maintain security. Material changes to these terms will be reflected on this page with an updated date.",
  "terms_section_contact_title": "Contact",
  "terms_section_contact_body": "For questions about these Terms of Use, contact legal@bebalna.app."
}
